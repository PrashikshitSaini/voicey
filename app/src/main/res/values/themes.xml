<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Voicey" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="android:windowBackground">@color/settings_background</item>
    </style>

    <style name="TextAppearance.Voicey.Section" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>

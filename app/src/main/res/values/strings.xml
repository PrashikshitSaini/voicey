    <string name="restricted_settings_title">Android 13+ extra step</string>
    <string name="restricted_settings_message">Android blocks sideloaded apps from enabling Accessibility by default. To unblock Voicey:\n\n1. Tap \"Open App Info\" below.\n2. On the App Info screen, tap the ⋮ menu at the top right.\n3. Tap \"Allow restricted settings\".\n4. Return here and tap \"Go to Accessibility settings\".\n\nIf you have already done this, just tap \"Go to Accessibility settings\".</string>
